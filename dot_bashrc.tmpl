# ~/.bashrc: executed by bash(1) for non-login shells.
# If not running interactively, don't do anything
case $- in
    *i*) ;;
      *) return;;
esac

# See bash(1) for more options /list of shopt options
HISTCONTROL=ignoreboth
shopt -s histappend
HISTSIZE=50
HISTFILESIZE=2000
shopt -s checkwinsize
shopt -s globstar

# make less more friendly for non-text input files, see lesspipe(1)
[ -x /usr/bin/lesspipe ] && eval "$(SHELL=/bin/sh lesspipe)"

# set a fancy prompt (non-color, unless we know we "want" color)
case "$TERM" in
    xterm-color|*-256color) color_prompt=yes;;
esac

if [ -x /usr/bin/tput ] && tput setaf 1 >&/dev/null; then
    source "$HOME/.config/bash/prompt.sh"
    PROMPT_COMMAND='LAST_EXIT="$?"; eval "PS1=\"$(__mkps1)\""'
else
    PS1='$\u@\h:\w\$ '
fi

if [[ "$TERM_PROGRAM" == "vscode" ]]; then
    unset PROMPT_COMMAND
    PS1=$'\[\e[02;32m\]\w\[\e[00m\]\$ '
	PS1="\n$PS1"
fi

if [[ -n "$NVIM" || -n "$RSTUDIO" ]]; then
    unset PROMPT_COMMAND
    PS1=$'\[\e[00;32m\]\w ❯ \[\e[00m\]'
	PS1="\n$PS1"
fi
    

# enable color support of ls and also add handy aliases
if [ -x /usr/bin/dircolors ]; then
    test -r ~/.dircolors && eval "$(dircolors -b ~/.dircolors)" || eval "$(dircolors -b)"
    alias fgrep='fgrep --color=auto'
    alias egrep='egrep --color=auto'
    alias watch='watch -c -n 0.5'
fi
# Add an "alert" alias for long running commands.  Use like so:
#   sleep 10; alert
alias alert='notify-send --urgency=low -i "$([ $? = 0 ] && echo terminal || echo error)" "$(history|tail -n1|sed -e '\''s/^\s*[0-9]\+\s*//;s/[;&|]\s*alert$//'\'')"'

# Alias definitions.
# You may want to put all your additions into a separate file like
# ~/.bash_aliases, instead of adding them here directly.
# See /usr/share/doc/bash-doc/examples in the bash-doc package.
alias ls='lsd'
alias grep='rg'
alias ll='lsd -alFg'
alias la='lsd -A'
alias lg="lazygit"
alias fd="fdfind"
alias tm="tmux"
alias tma="tmux attach -t 0"
alias ch="chezmoi"
alias cl="clear"
alias csvlens="csvlens --colorful"
alias timeit="/usr/bin/time -f %Mkb:%es"


if [ -f ~/.bash_aliases ]; then
    . ~/.bash_aliases
fi

# colored GCC warnings and errors
export GCC_COLORS='error=01;31:warning=01;35:note=01;36:caret=01;32:locus=01:quote=01'

# source profile.d
if [ -d /etc/profile.d ]; then
  for i in /etc/profile.d/*.sh; do
    if [ -r $i ]; then
      . $i
    fi
  done
  unset i
fi

# Direnv stuff
_direnv_hook() {
  local previous_exit_status=$?;
  trap -- '' SIGINT;
  eval "$("/usr/bin/direnv" export bash)";
  trap - SIGINT;
  return $previous_exit_status;
};
if ! [[ "${PROMPT_COMMAND:-}" =~ _direnv_hook ]]; then
  PROMPT_COMMAND="_direnv_hook${PROMPT_COMMAND:+;$PROMPT_COMMAND}"
fi

completions_dir="$HOME/.config/bash/completions"
[ -s "$completions_dir/chezmoi" ] && \. "$completions_dir/chezmoi"
[ -s "$completions_dir/trash" ] && \. "$completions_dir/trash"

export NVM_DIR="$HOME/.nvm"
[ -s "$NVM_DIR/nvm.sh" ] && \. "$NVM_DIR/nvm.sh"  # This loads nvm
[ -s "$NVM_DIR/bash_completion" ] && \. "$NVM_DIR/bash_completion"  # This loads nvm bash_completion


function y() {
	local tmp="$(mktemp -t "yazi-cwd.XXXXXX")" cwd
	yazi "$@" --cwd-file="$tmp"
	IFS= read -r -d '' cwd < "$tmp"
	[ -n "$cwd" ] && [ "$cwd" != "$PWD" ] && builtin cd -- "$cwd"
	rm -f -- "$tmp"
}

export TS_IP="$(tailscale ip -4)"
export EDITOR="nvim"
export PATH="$HOME/.local/bin:$HOME/.cargo/bin:$HOME/.local/share/nvim/mason/bin:$PATH"
{{- if eq .chezmoi.osRelease.id "ubuntu" }}
export IP="$(hostname -I | awk '{print $1}')"
{{- else if eq .chezmoi.osRelease.id "arch" }}
if [ -z "$WAYLAND_DISPLAY" ] && [ -n "$XDG_VTNR" ] && [ "$XDG_VTNR" -eq 1 ] ; then
    exec sway
fi
export IP="$(ip -o -4 addr list wlan0 | awk '{print $4}' | cut -d/ -f1)"
{{- end }}


# some useful functions
function marimo-serve() {
    uv run marimo edit --headless --watch --host $TS_IP --no-token
}

function chdiffnvim() {
	diff -bur --color=always ~/.local/share/chezmoi/dot_config/nvim/ ~/.config/nvim/ -x ".git*" -x "*stylua*" -x "lazy-lock.json"
}

function watchlastlog() {
	watch 'tail -n 30 "$(find logs | sort --reverse | head -n 1)"'
}

[ -f ~/.fzf.bash ] && source ~/.fzf.bash
eval "$(zoxide init bash --cmd j)"
