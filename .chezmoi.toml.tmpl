[git]
  autoPush=true

[data]
  name="eno:{{ .chezmoi.hostname }}"

[merge]
    command = "nvim"
    args = [
        "-d",
        {{ printf "%q" "{{ .Destination }}" }},
        {{ printf "%q" "{{ .Source }}" }},
        {{ printf "%q" "{{ .Target }}" }},
    ]

encryption = "age"
[age]
    identity = "~/.config/chezmoi/key.txt"
    recipient = ""
